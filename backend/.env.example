# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — set DB_ENGINE=postgresql to use Postgres, leave blank for SQLite (default)
DB_ENGINE=sqlite

# PostgreSQL credentials (only needed if DB_ENGINE=postgresql)
DB_NAME=booksearch
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_HOST=localhost
DB_PORT=5432

# AI APIs (use one of the following)
ANTHROPIC_API_KEY=your-anthropic-key
OPENAI_API_KEY=your-openai-key

# LM Studio (local, no key needed)
LM_STUDIO_BASE_URL=http://localhost:1234/v1

# Which AI provider to use: anthropic | openai | lmstudio
AI_PROVIDER=anthropic
